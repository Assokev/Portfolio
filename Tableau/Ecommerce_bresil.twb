      </column>
      <column caption='Délai réel (jours)' datatype='integer' name='[Calculation_3739145519710209]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[order_purchase_timestamp], [order_delivered_customer_date])' />
      </column>
      <column caption='Délai estimé (jours)' datatype='integer' name='[Calculation_3739145520332802]' role='measure' type='quantitative'>
